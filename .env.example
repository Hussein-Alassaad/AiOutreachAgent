# =============================================================================
# NEXARIS AI OUTREACH AGENT — environment variables
# =============================================================================
# This file is committed and contains NO real secrets. Copy the relevant section
# into agent/.env and dashboard/.env, then fill in real values. Those two files
# are gitignored and must never be committed.
#
#   cp .env.example agent/.env
#   cp .env.example dashboard/.env
#
# The "needed by" note on each block tells you which phase actually requires it —
# you do not need everything filled in to start.
# =============================================================================


# -----------------------------------------------------------------------------
# AGENT (agent/.env) — the Python agent, runs on the always-on server
# -----------------------------------------------------------------------------

# --- Supabase --- needed by: Phase 1 ---
# Project URL and the SERVICE ROLE key (Settings > API in the Supabase dashboard).
# The service role key bypasses Row Level Security. It is safe here because the
# agent runs on a trusted server. NEVER put it in the dashboard.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=

# --- Claude API --- needed by: Phase 4 ---
# From console.anthropic.com. Haiku handles analysis/scoring/founder detection
# (high volume, cost-efficient); Sonnet writes the messages (better quality).
ANTHROPIC_API_KEY=
MODEL_ANALYSIS=claude-haiku-4-5-20251001
MODEL_MESSAGES=claude-sonnet-5

# --- WhatsApp --- needed by: Phase 7 (sending) and Phase 8 (notifications) ---
# Provider not finalised yet — see open decision Q1 in REQUIREMENTS_COVERAGE.md.
WHATSAPP_PROVIDER=twilio
WHATSAPP_API_KEY=
WHATSAPP_API_SECRET=
WHATSAPP_FROM_NUMBER=

# --- Runtime --- needed by: Phase 2 ---
# Timezone that each account's run time is interpreted in.
TIMEZONE=Asia/Beirut
# HEADLESS=false shows a visible browser — useful while building discovery in
# Phase 3. Must be true on the server.
HEADLESS=true
# Safety brake for local testing: caps leads per account regardless of the
# dashboard setting. Leave empty in production.
DEV_MAX_LEADS_PER_ACCOUNT=

# --- Proxies --- needed by: Phase 10 ---
# NOTE: proxy credentials are stored PER ACCOUNT in the Supabase `accounts` table
# and edited from the dashboard — not here. Listed only so you know where they
# live. Each account gets one dedicated sticky residential IP, never shared, and
# rotating or datacenter proxies must never be used.


# -----------------------------------------------------------------------------
# DASHBOARD (dashboard/.env) — the React PWA, deployed to Vercel
# -----------------------------------------------------------------------------
# Only VITE_-prefixed vars reach the browser. Use the ANON key here, never the
# service role key — anything in this file is publicly visible in the built app.
# Row Level Security is what protects the data.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=
